<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Private Vault</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <style>
        body { margin: 0; padding: 0; font-family: 'Lato', sans-serif; background: #fff; overflow-x: hidden; height: 100vh; }
        
        .header {
            position: relative;
            text-align: center;
            background: linear-gradient(60deg, rgba(84,58,183,1) 0%, rgba(0,172,193,1) 100%);
            color: white;
            /* 調整為 80vh，讓整體波浪下壓到頁面底部 1/5 處 */
            height: 80vh; 
            display: flex;
            flex-direction: column;
        }

        .inner-header {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            z-index: 10;
        }

        h1 { font-weight: 300; letter-spacing: 2px; font-size: 36px; margin-bottom: 20px; }
        input { padding: 12px 20px; border-radius: 25px; border: none; width: 220px; text-align: center; font-size: 16px; outline: none; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        button { padding: 10px 35px; margin-top: 20px; border-radius: 25px; border: 2px solid white; background: transparent; color: white; font-weight: bold; cursor: pointer; transition: 0.3s; }
        button:hover { background: white; color: #00acc1; }
        #msg { margin-top: 15px; font-size: 14px; color: #ffdede; min-height: 1.2em; font-weight: bold; }

        /* 原始大幅度波浪容器設定 */
        .waves {
            position: relative;
            width: 100%;
            height: 15vh; /* 給予足夠高度展現大幅度 */
            margin-bottom: -7px;
            min-height: 100px;
            max-height: 150px;
        }

        /* 原始 4 層動畫設定 */
        .parallax > use {
            animation: move-forever 25s cubic-bezier(.55,.5,.45,.5) infinite;
        }
        .parallax > use:nth-child(1) { animation-delay: -2s; animation-duration: 7s; }
        .parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; }
        .parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; }
        .parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 20s; }

        @keyframes move-forever {
            0% { transform: translate3d(-90px,0,0); }
            100% { transform: translate3d(85px,0,0); }
        }

        /* 右下角動態時鐘標記 */
        #footer-tag {
            position: fixed;
            bottom: 15px;
            right: 20px;
            color: #00acc1;
            font-size: 11px;
            z-index: 5;
            letter-spacing: 1px;
            font-family: 'Courier New', monospace;
        }

        #content-main { display: none; width: 100%; min-height: 100vh; background: #fff; position: absolute; top: 0; left: 0; z-index: 999; }

        @media (max-width: 768px) {
            .waves { height: 40px; min-height: 40px; }
            h1 { font-size: 24px; }
            .header { height: 75vh; }
        }
    </style>
</head>
<body>

<div id="login-ui">
    <div class="header">
        <div class="inner-header">
            <h1>Private Vault</h1>
            <input type="password" id="password" placeholder="ENTER PASSWORD">
            <button onclick="unlock()">UNLOCK</button>
            <p id="msg"></p>
        </div>

        <svg class="waves" xmlns="http://www.w3.org/2000/svg" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
            <defs>
                <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
            </defs>
            <g class="parallax">
                <use href="#gentle-wave" x="48" y="0" fill="rgba(255,255,255,0.7)" />
                <use href="#gentle-wave" x="48" y="3" fill="rgba(255,255,255,0.5)" />
                <use href="#gentle-wave" x="48" y="5" fill="rgba(255,255,255,0.3)" />
                <use href="#gentle-wave" x="48" y="7" fill="#ffffff" />
            </g>
        </svg>
    </div>
    <div id="footer-tag"></div>
</div>

<div id="content-main"></div>

<script>
    // 右下角動態時鐘 (YYYY-MM-DD HH:MM:SS)
    function updateTime() {
        const now = new Date();
        const y = now.getFullYear(), m = String(now.getMonth() + 1).padStart(2, '0'), d = String(now.getDate()).padStart(2, '0');
        const hh = String(now.getHours()).padStart(2, '0'), mm = String(now.getMinutes()).padStart(2, '0'), ss = String(now.getSeconds()).padStart(2, '0');
        document.getElementById('footer-tag').innerText = `${y}-${m}-${d} ${hh}:${mm}:${ss} @ GitHub API`;
    }
    setInterval(updateTime, 1000); updateTime();

    const CFG = {
        user: "pipi-family",
        repo: "my-private-data",
        // 🔑 貼上您重新產生的 Token (經 btoa 混淆後)
        _k: "Z2hwX1JDcmh6VGhjQXBtenphZGJKNnR5NG04SklkVDB4QjF2MzE3ZQ==" 
    };

    async function fetchFromVault(file) {
        const url = `https://api.github.com/repos/${CFG.user}/${CFG.repo}/contents/${file}`;
        const res = await fetch(url, {
            headers: { "Authorization": `token ${atob(CFG._k)}` }
        });
        if (!res.ok) throw new Error("Vault Access Denied");
        const data = await res.json();
        const base64Content = data.content.replace(/\s/g, '');
        return decodeURIComponent(atob(base64Content).split('').map(c => 
            '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)
        ).join(''));
    }

    async function unlock() {
        const msg = document.getElementById('msg');
        const pwd = document.getElementById('password').value;
        const hash = CryptoJS.SHA256(pwd).toString();
        msg.innerText = "Connecting...";

        try {
            const passStr = await fetchFromVault("pass.json");
            const storedHash = JSON.parse(passStr).hash;
            if (hash === storedHash) {
                const html = await fetchFromVault("source.html");
                document.getElementById('login-ui').style.display = "none";
                const main = document.getElementById('content-main');
                main.style.display = "block";
                main.innerHTML = html;
            } else {
                msg.innerText = "Access Denied.";
            }
        } catch (e) {
            msg.innerText = "Error: Token Revoked or Network Issue.";
        }
    }
    document.getElementById('password').addEventListener("keydown", e => { if (e.key === "Enter") unlock(); });
</script>
</body>
</html>
